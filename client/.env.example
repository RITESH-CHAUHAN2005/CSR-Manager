# Copy to .env to configure the client.

# Use the live Express/MongoDB backend instead of the in-memory mock.
# Leave unset (or false) to run the client standalone with seed data.
VITE_USE_API=false

# Backend origin for split-domain production builds (frontend and API on
# different hosts). Leave UNSET in dev — Vite proxies /api to localhost:5000.
# Example for a Railway backend (no trailing slash, no /api):
# VITE_API_URL=https://csr-manager-production.up.railway.app
