# Copy to .env and fill in real values. NEVER commit the real .env.
NODE_ENV=development
PORT=5000

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/csr_manager

# Auth — use long random strings in production (e.g. `openssl rand -hex 48`)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=1d

# Comma-separated list of allowed frontend origins (CORS)
CLIENT_ORIGIN=http://localhost:5173

# Seed admin (used by `npm run seed`). Change the password immediately after seeding.
SEED_ADMIN_EMAIL=admin@csr.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_USER_EMAIL=user@csr.com
SEED_USER_PASSWORD=User@123
